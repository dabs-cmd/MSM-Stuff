# Ethereal Workshop
import random
import time
import etheworkshopbios

ELEMENTS = ["plasma", "shadow", "mech", "crystal", "poison"]


def attunement_timer(total_seconds, element):
    while total_seconds > 0:
        mins, secs = divmod(total_seconds, 60)
        print(f"{mins:02d}:{secs:02d}")
        time.sleep(1)
        total_seconds -= 1
    print(f"You have attuned the {element} element to a meeb!")

def synthesis_timer(total_seconds):
    while total_seconds > 0:
        mins, secs = divmod(total_seconds, 60)
        print(f"{mins:02d}:{secs:02d}")
        time.sleep(1)
        total_seconds -= 1

def element_choice():
    elemchoice = input("Alright! Select an element above to attune to a Meeb!: "
    "(q to return to menu): ").lower()
    return elemchoice

def menu():
    print("Welcome to Ethereal Workshop! What would you like to do on the island?")
    selection = input("1. Attunement "
                  "2. Synthesis "
                  "3. Monster List ")
    return selection

def synthesis():
    valid = False
    while not valid:
        synel1 = input("First Element: ").lower()
        if synel1 == "q":
            return
        synel2 = input("Second Element: ").lower()
        if synel2 == "q":
            return
        synel3 = input("Third Element: ").lower()
        if synel3 == "q":
            return

        chosen = [synel1, synel2, synel3]


        if any(e not in attuned for e in chosen):
            print("Invalid element!")
            continue
        if len(set(chosen)) != 3:
            print("You cannot choose the same element!")
            continue
        if any(attuned[e] < 1 for e in chosen):
            print("Insufficient meebs!")
            continue

        valid = True

        combo = frozenset(chosen)

        found_monster = None
        for name,data in monsters.items():
            if data['elements'] == combo:
                found_monster = name
                break
        if found_monster is None:
            print("No monster matches that combination!")
            continue

    roll = random.random()
    if roll < monsters[found_monster]['chance']:
        synthesis_timer(66)
        print("success!")
        print(f"You've synthesized a {found_monster}")
        for elem in chosen:
            attuned[elem] -= 1
        monsters_made[found_monster] = monsters_made.get(found_monster, 0) + 1
    else:
        synthesis_timer(10)
        print("failure! better luck next time...")
        for elem in chosen:
            if random.random() > 0.5:
                refund = random.randint(1,1)
                attuned[elem] += refund
                print(f"Refunded {refund} {elem} meebs!")

def synthesis_quad():
    valid = False
    while not valid:

        # show monsters they can use as a base
        # (only triples they actually have in monsters_made)
        print("Your available triple monsters:")
        for name in monsters_made:
            if len(monsters[name]["elements"]) == 3:
                print(f"  {name}")

        base_name = input("Choose a triple monster to use as base (Q to cancel): ").strip().capitalize()
        if base_name == "Q":
            return
        if base_name not in monsters_made:
            print("You don't own that monster!")
            continue
        if len(monsters[base_name]["elements"]) != 3:
            print("You must use a triple element monster as the base!")
            continue

        # choose the new 4th element
        new_elem = input("Choose the new element to add: ").lower()
        if new_elem == "q":
            return

        if new_elem not in ELEMENTS:
            print("Invalid input!")
            continue
        if new_elem in monsters[base_name]["elements"]:
            print("That element is already in your base monster!")
            continue
        # check the triple elements (need 2 each)
        enough_meebs = True
        for elem in monsters[base_name]["elements"]:
            if attuned[elem] < 2:
                print(f"You need at least 2 {elem} meebs!")
                enough_meebs = False
                break
        if not enough_meebs:
            continue
        if attuned[new_elem] < 3:
            print(f"You need at least 3 {new_elem} meebs!")
            continue

        chosen = list(monsters[base_name]["elements"]) + [new_elem]
        combo = frozenset(chosen)

        found_monster = None
        for name, data in monsters.items():
            if data['elements'] == combo:
                found_monster = name
                break
        if found_monster is None:
            print("No monster matches that combination!")
            continue
        valid = True

    roll = random.random()
    if roll < monsters[found_monster]['chance']:
        synthesis_timer(78)
        print("success!")
        for elem in monsters[base_name]["elements"]:
            attuned[elem] -= 2
            attuned[new_elem] -= 3
        # kills old monster
        monsters_made[base_name] -= 1
        if monsters_made[base_name] == 0:
            del monsters_made[base_name]
        monsters_made[found_monster] = monsters_made.get(found_monster, 0) + 1
        print(f"You've synthesized a {found_monster}!")

    else:
        synthesis_timer(17)
        print("Failure! Better luck next time...")
        for elem in chosen:
            if random.random() > 0.43:
                refund = random.randint(1, 2)
                attuned[elem] += refund
                print(f"Refunded {refund} {elem} meebs!")

