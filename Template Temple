def element_sequence():
    elements = ["plant", "cold", "air", "water", "earth", "fire"]
    entered = []
    print("Input the 6 elements adjacent to the amount of elements the template has:")
    for i in range(6):
        el = input(f"Element {i+1}: ").lower().strip()
        if el not in elements:
            print("Invalid element. Stick to what the Injector can offer you.")
            return False
        if el in entered:
            print(f"{el} has already been used. Each element must be unique.")
            return False
        entered.append(el)

    if frozenset(entered) == monsters["Naturalus"]["elements"]:
        return True
    else:
        print("That sequence doesn't match a known template.")
        return False

def element_injector():
    elements = ["plant", "cold", "air", "water", "earth", "fire"]
    while True:
        if not monsters_made:
            print("You have no monsters to inject!")
            return

        print("Your monsters:")
        for name, count in monsters_made.items():
            if monsters[name]['value'] != 6:
                marker = "X"
            else:
                marker = " "
            print(f"  [{marker}] {name}: {count}x")

        for element in elements:
            print(element, end=" ")
        print()

        base_name = input("Choose a template monster to inject (Q to cancel): ").strip().capitalize()


        if base_name == "Q":
            return
        if base_name not in monsters_made:
            print("You don't own that monster!")
            continue
        if monsters[base_name]['value'] != 6:
            print("The Injector only has plans for one monster...")
            continue

        if not element_sequence():
            print("The injection failed before it could even begin...")
            continue

        roll = random.random()
        monsters_made[base_name] -= 1
        if monsters_made[base_name] == 0:
            del monsters_made[base_name]

        if roll < monsters["Naturalus"]['chance']:
            elem_multip_timer(96)
            monsters_made["Naturalus"] = monsters_made.get("Naturalus", 0) + 1
            print("Naturalus has emerged from the injection!")
        else:
            elem_multip_timer(48)
            print("The injection destabilized... the template was lost.")

def menu():
    print("Welcome to Template Temple!")
    while True:
        choice = input("What would you like to do?\n"
                       "1. Emerge Nuth  2. Elemental Multiplier\n"
                       "3. Element Injector  4. Monster List & Island Bio (Q to quit): ").upper()
        if choice == "Q":
            print("Goodbye!")
            break
        elif choice == "1":
            spawn_nuth()
        elif choice == "2":
            element_multiplier()
        elif choice == "3":
            element_injector()
        elif choice == "4":
            if not monsters_made:
                print("You haven't made any monsters yet!")
            else:
                for name, count in monsters_made.items():
                    print(f"  {name}: {count}x")
            bio_choice = input("Press E to learn more about the island (Q to quit): ").upper()
            if bio_choice == "E":
                bio()
            pass

menu()
