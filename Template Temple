def spawn_nuth():

    while True:
        nuth = input("Press N to birth a new Nuth: ").upper()
        if nuth == "N":
            print("Nuth has arose!")
            monsters_made["Nuth"] = monsters_made.get("Nuth", 0) + 1
            break
        elif nuth == "Q":
            return
        else:
            print("N is for Nuth, and NOTHING else...")

def elem_multip_timer(total_seconds):
    while total_seconds > 0:
        mins, secs = divmod(total_seconds, 60)
        print(f"{mins:02d}:{secs:02d}")
        time.sleep(1)
        total_seconds -= 1


